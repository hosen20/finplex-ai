# -------------------------------------------------------------------
# Finplex AI local development environment
# Copy this file to .env and keep .env out of Git.
# -------------------------------------------------------------------

APP_NAME="Finplex AI"
ENVIRONMENT=local
LOG_LEVEL=INFO

# Local application ports
API_PORT=8000
MODEL_SERVER_PORT=8001
GUARDRAILS_PORT=8002
WEB_PORT=5173

# Postgres + pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finplex
POSTGRES_USER=finplex
POSTGRES_PASSWORD=finplex_password
DATABASE_URL=postgresql+psycopg://finplex:finplex_password@localhost:5432/finplex

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=finplex_minio
MINIO_ROOT_PASSWORD=finplex_minio_password
MINIO_BUCKET_INVOICES=finplex-invoices
MINIO_SECURE=false

# Kafka + Zookeeper
ZOOKEEPER_PORT=2181
KAFKA_LOCAL_PORT=29092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

KAFKA_INVOICE_UPLOADED_TOPIC=invoice.uploaded
KAFKA_INVOICE_EXTRACTED_TOPIC=invoice.extracted
KAFKA_INVOICE_SCORED_TOPIC=invoice.scored
KAFKA_INVOICE_DRAFTED_TOPIC=invoice.drafted
KAFKA_INVOICE_REVIEWED_TOPIC=invoice.reviewed
KAFKA_AUDIT_EVENTS_TOPIC=audit.events

KAFKA_CLIENT_ID=finplex-api
EVENT_PUBLISHER_BACKEND=kafka
INVOICE_STORAGE_BACKEND=local

# Local service URLs
API_URL=http://localhost:8000
MODEL_SERVER_URL=http://localhost:8001
GUARDRAILS_URL=http://localhost:8002

# Local-first ERP/CRM
ERP_PROVIDER=local
CRM_PROVIDER=local

# LLM provider
LLM_PROVIDER=groq
GROQ_API_KEY=replace-me-locally
GROQ_MODEL=llama-3.1-8b-instant